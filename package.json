{
  "name": "modellus",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "test": "npx playwright test",
    "build:offline": "node electron/build-offline.js",
    "icons": "node electron/generate-icons.js",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "agents": "^0.7.5",
    "devextreme": "25.2.3",
    "jquery": "^3.7.1",
    "mathlive": "^0.103.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "http-server": "^14.1.1"
  },
  "build": {
    "appId": "com.modellus.editor",
    "productName": "Modellus",
    "directories": {
      "output": "dist"
    },
    "icon": "build/icon.png",
    "files": [
      "**/*",
      "!tests/**",
      "!test-results/**",
      "!functions/**",
      "!sdk/aiSdk.js",
      "!sdk/userSdk.js",
      "!build/**",
      "!electron/build-offline.js",
      "!electron/generate-icons.js",
      "!editor.js",
      "!editor.html",
      "!playwright.config.js",
      "!login.html",
      "!login.js",
      "!marketplace.html",
      "!marketplace.css",
      "!marketplace.js",
      "!index.html",
      "!CNAME",
      "!AGENTS.md"
    ],
    "mac": {
      "target": "dmg"
    },
    "dmg": {
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
